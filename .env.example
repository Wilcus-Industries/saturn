# Generate with: npx @better-auth/cli@latest secret
BETTER_AUTH_SECRET=
# Base URL of this app
BETTER_AUTH_URL=http://localhost:3000

# Neon POOLED connection string (postgresql://...-pooler...neon.tech/...?sslmode=require)
DATABASE_URL=

# Google OAuth (Web application client) for better-auth sign-in —
# redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (test mode) — prefer a restricted key (rk_test_...) over sk_test_...
STRIPE_SECRET_KEY=
# From `stripe listen --forward-to localhost:3000/api/auth/stripe/webhook` locally,
# or the dashboard webhook endpoint secret in prod
STRIPE_WEBHOOK_SECRET=
# Subscription price IDs (test and live mode differ)
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=

# Platform OpenRouter key that pays for built-in model credits on paid tiers.
# Optional — when unset, paid users fall back to their own key (BYOK) like
# free users.
PLATFORM_OPENROUTER_KEY=

# Shared secret for the service-to-service endpoints (/api/cron,
# /api/event-subscriptions, /api/events — all `Authorization: Bearer
# <CRON_SECRET>`). These are manual/transitional triggers now that scheduling
# and event delivery run in-process; the endpoints refuse to run when unset.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Set to 1 to run in-process background work (the per-minute cron scheduler
# and the Discord Gateway event listener — instrumentation.ts). Set in
# /etc/saturn/saturn.env in prod; leave unset in dev unless testing loops
# locally (then add it to .env.local).
SATURN_BACKGROUND=
