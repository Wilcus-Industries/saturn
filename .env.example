# Generate with: npx @better-auth/cli@latest secret
BETTER_AUTH_SECRET=
# Base URL of this app
BETTER_AUTH_URL=http://localhost:3000

# Neon POOLED connection string (postgresql://...-pooler...neon.tech/...?sslmode=verify-full —
# use verify-full, not require: pg v8.16+ treats them the same but warns on 'require',
# and pg v9 will downgrade 'require' to weaker libpq semantics).
# Locally this must be the Neon DEV BRANCH url (scripts/dev-db.sh create prints it),
# never the prod branch — the prod url lives only in /etc/saturn/saturn.env on the Pi
# (deploy.sh ssh-reads it from there for migrations).
DATABASE_URL=

# Google OAuth (Web application client) for better-auth sign-in —
# redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (test mode) — prefer a restricted key (rk_test_...) over sk_test_...
STRIPE_SECRET_KEY=
# From `stripe listen --forward-to localhost:3000/api/auth/stripe/webhook` locally,
# or the dashboard webhook endpoint secret in prod
STRIPE_WEBHOOK_SECRET=
# Subscription price IDs (test and live mode differ)
STRIPE_PRICE_PRO=
STRIPE_PRICE_MAX=

# Platform OpenRouter key that pays for built-in model credits on paid tiers.
# Optional — when unset, paid users fall back to their own key (BYOK) like
# free users.
PLATFORM_OPENROUTER_KEY=

# unix socket of the rootless podman API (dedicated 'sandboxes' user) — unset
# disables linux sandboxes; see deploy/sandboxes.md
SANDBOX_PODMAN_SOCKET=

# Set to 1 to start background work (cron scheduler + Discord gateway + Telegram
# poller + sandbox reaper) in `next dev` — `npm run dev:full` sets it for you.
# Only use against the Neon dev branch: with prod bot tokens in active workflows,
# a second Telegram getUpdates consumer 409s against prod and Discord events
# double-deliver. scripts/dev-db.sh deactivates all copied workflows for this
# reason — reactivate only what you test, preferably with dev bot tokens.
SATURN_DEV_BACKGROUND=

# ============================================================================
# SELF_HOSTED single-user mode
# ============================================================================
# Set to 1 to run Saturn as a single-owner instance: no sign-in, no plans,
# limits, or credits (everything unlimited, cron floor 1 min). A synthetic
# "owner" user is auto-created on first boot with the example workflow seeded.
#
# WARNING: THERE IS NO AUTH ON THE DASHBOARD under this flag. Bind the app to
# localhost (BETTER_AUTH_URL=http://localhost:3000) or put reverse-proxy auth
# (e.g. basic auth / an SSO proxy) in front of it. Anyone who can reach the
# port is the owner.
#
# Unset (or anything but 1) = exactly today's multi-user, Google + Stripe
# behavior.
SELF_HOSTED=

# Vars that become UNNECESSARY when SELF_HOSTED=1 (no Google sign-in, no Stripe
# plugin is ever constructed): GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET,
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_PRO, STRIPE_PRICE_MAX.
#
# Still REQUIRED under the flag: DATABASE_URL (any Postgres with the pgvector
# extension, not only Neon), BETTER_AUTH_URL, BETTER_AUTH_SECRET. And
# PLATFORM_OPENROUTER_KEY becomes the ONLY funding for model calls (there is no
# per-user BYOK), so it is required for any model/agent/memory features to work.
#
# When creating better-auth's tables, run the migrate WITH SELF_HOSTED=1 set so
# the Stripe plugin's `subscription` table is skipped consistently:
#   SELF_HOSTED=1 npx @better-auth/cli@latest migrate --config lib/auth.ts

# Static bearer token guarding the hosted MCP server at /mcp under SELF_HOSTED
# (external agents send `Authorization: Bearer <this>`). There is no OAuth in
# single-user mode. Unset = the MCP server 401s on every request (no agent
# access). Generate any long random string.
SELF_HOSTED_MCP_TOKEN=

# Per-container sandbox resource quotas for SELF_HOSTED mode (no tiers to size
# them). All optional — non-numeric / non-positive falls back to the default.
# Defaults shown; dial to your hardware.
SANDBOX_MEMORY_MB=1024
SANDBOX_CPUS=2
SANDBOX_DISK_MB=8192
SANDBOX_EXEC_TIMEOUT_S=600
