# Per-user sandbox image for Saturn agent code execution.
#
# WHY a dedicated image: every sandbox container runs from this one image, so
# the toolchain agents get is fixed and auditable here — nothing is installed at
# runtime (the rootfs is mounted read-only; only the named volume at /work and a
# tmpfs /tmp are writable).
#
# Built on the Pi AS THE sandboxes USER (rootless podman stores the image in that
# user's own storage, which is the only storage the libpod socket at
# /run/sandboxes/podman.sock can see):
#   sudo -u sandboxes podman build -t saturn-sandbox:latest -f deploy/Containerfile.sandbox deploy/
# (setup-sandboxes.sh does this for you; this header is the manual-rebuild recipe.)

FROM debian:bookworm-slim

# Single RUN so the install + list-cleanup collapse into one layer (a separate
# `rm` layer would keep the apt lists in the lower layer and bloat the image).
# --no-install-recommends keeps the image lean — agents get exactly this set.
# Node comes from NodeSource (22.x), not bookworm's stale v18 — agents can't
# install toolchains at runtime anyway (read-only rootfs; tier memory limits
# OOM-kill big extractions). Anything an agent needs beyond pip/npm-into-/work
# must be added HERE.
RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      python3 \
      python3-pip \
      python3-venv \
      build-essential \
      procps \
      coreutils \
      bash \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# A real login user so tools that read $HOME / expect a passwd entry behave.
# uid 1000 matches the `--user 1000` the app passes at container-create time, and
# the read-only rootfs means /home/sandbox is only writable via the tmpfs/volume.
RUN useradd -m -u 1000 -s /bin/bash sandbox

# /work must be owned by uid 1000 IN THE IMAGE: podman's copy-up clones the image
# directory's ownership onto a fresh named volume, and a bare WORKDIR would create
# it root-owned — leaving every volume 0:0/755 and all writes from uid 1000 EPERM.
RUN mkdir -p /work && chown 1000:1000 /work

WORKDIR /work

# Drop to the unprivileged uid for every process the app exec's into the box.
USER 1000

# No ENTRYPOINT / CMD on purpose: the app creates each container with the command
# ["sleep","infinity"] so the box idles, and exec's individual agent commands in.
